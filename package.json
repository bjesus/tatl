{
  "name": "atl-tableau",
  "version": "1.0.0",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "bun run src/index.ts",
    "test": "bun test",
    "build:cli": "bun build --compile src/index.ts --outfile atl",
    "build:web": "bun run src/build-html.ts",
    "build:standalone": "bun run build:web && bun build --compile --minify src/standalone.ts --outfile atl"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
